# ── LLM Provider ──────────────────────────────────────────
# Required: OpenAI (default) or Anthropic
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Model to use (default: gpt-4o-mini for cost efficiency)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, claude-3-5-sonnet-20241022
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai   # openai | anthropic

# ── Search Tools ──────────────────────────────────────────
# Optional: Tavily gives better results than DuckDuckGo
# Sign up free at https://tavily.com
TAVILY_API_KEY=tvly-...

# ── LangSmith Tracing (optional) ──────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=multi-agent-research

# ── App Settings ──────────────────────────────────────────
MAX_SEARCH_RESULTS=5
MAX_SUBTASKS=4
METRICS_DB_PATH=./metrics.db
LOG_LEVEL=INFO
