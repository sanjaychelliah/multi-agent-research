# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: openai | anthropic | openrouter | ollama

LLM_PROVIDER=openai

# Model name — must match the chosen provider's naming convention:
#   openai      → gpt-4o, gpt-4o-mini, gpt-4-turbo
#   anthropic   → claude-3-5-sonnet-20241022, claude-3-haiku-20240307
#   openrouter  → openai/gpt-4o, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-8b-instruct, etc.
#   ollama      → llama3.2, mistral, qwen2.5, deepseek-r1, phi3, etc.
LLM_MODEL=gpt-4o-mini

# ── Provider API Keys (fill in only the one you need) ─────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — https://openrouter.ai/keys
# Gives access to 200+ models (OpenAI, Anthropic, Meta, Mistral, Google, etc.)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # default, no need to change

# Ollama (local) — https://ollama.com
# No API key needed. Just have Ollama running: `ollama serve`
# Pull a model first: `ollama pull llama3.2`
# OLLAMA_BASE_URL=http://localhost:11434/v1            # default, no need to change

# ── Search Tools ──────────────────────────────────────────────────────────────
# Optional: Tavily gives richer results than DuckDuckGo (free fallback)
# Sign up free at https://tavily.com
TAVILY_API_KEY=tvly-...

# ── LangSmith Tracing (optional) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=multi-agent-research

# ── App Settings ──────────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5
MAX_SUBTASKS=4
METRICS_DB_PATH=./metrics.db
LOG_LEVEL=INFO
